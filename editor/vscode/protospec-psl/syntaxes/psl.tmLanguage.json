{
  "name": "PSL",
  "scopeName": "source.psl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.psl",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.psl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.psl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.psl",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.psl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.psl",
          "match": "\\b(protocol|version|field|bitfield|byte_order|enum|checksum|covers|when|length_ref|scale|offset|display|const|range|import|message|request|response|notification|transport|optional|default|auto)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.psl",
          "match": "\\b(uint[0-9]+|int[0-9]+|bytes|string|bool|number|boolean|object|array)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "constant.language.psl",
          "match": "\\b(big-endian|little-endian)\\b"
        },
        {
          "name": "support.function.psl",
          "match": "\\b(internet-checksum|crc16|crc32)\\b"
        },
        {
          "name": "support.type.psl",
          "match": "\\b(ipv4|ipv6|mac)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.psl",
          "match": "(>|<|>=|<=|==|!=|\\.\\.)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.psl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
