protocol H264NAL version "1.0" {
    byte_order big-endian;

    bitfield {
        field forbidden_zero: uint1;
        field nal_ref_idc: uint2;
        field nal_unit_type: uint5 enum {
            1 = "Slice", 5 = "IDR", 6 = "SEI",
            7 = "SPS", 8 = "PPS", 9 = "AUD",
            24 = "STAP-A", 28 = "FU-A"
        };
    }

    field payload: bytes;
}
